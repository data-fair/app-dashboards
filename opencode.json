{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "sudo *": "deny"
    }
  },
  "mcp": {
    "vuetify": {
      "type": "remote",
      "url": "https://mcp.vuetifyjs.com/mcp",
      "enabled": false
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true
    }
  }
}